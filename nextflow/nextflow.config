/*
 * nf-core/rnaseq — profil Scaleway Kapsule
 *
 * Infrastructure :
 *   - Pool orchestrateur : BASIC3-X4C-16G (Nextflow head job, toujours actif)
 *   - Pool compute       : POP2-HM-8C-64G (STAR jobs, autoscale 0→N)
 *   - Workdir            : SFS NFS RWX monté sur /data/workdir
 *   - Référence          : SFS NFS RWX monté sur /data/reference (index STAR)
 *   - Scratch STAR       : workdir NFS (temp SAM/BAM — voir note performance)
 *
 * Note stockage scratch :
 *   Les fichiers SAM temporaires de STAR sont écrits dans le workdir NFS (SFS).
 *   Pour un throughput maximal en production, passer sur des PVC SBS dynamiques
 *   (StorageClass 'star-scratch', 2 TB, 25 687 IOPS / 201,5 MB/s) : décommentez
 *   le bloc 'volumeClaim' dans withName:STAR_ALIGN et supprimez 'scratch = true'.
 */

params {
  max_cpus   = 7
  max_memory = '52.GB'
  max_time   = '8.h'
}

profiles {

  scaleway_kapsule {
    // Le head Nextflow et les tâches partagent leurs résultats intermédiaires
    // via le PVC RWX.
    workDir = '/data/workdir'

    k8s {
      namespace        = 'bioinformatics'
      serviceAccount   = 'nextflow'
      // PVC RWX SFS — partagé par tous les pods task (workdir Nextflow)
      storageClaimName = 'nf-workdir-pvc'
      storageMountPath = '/data/workdir'
      pullPolicy       = 'IfNotPresent'
      // nf-reference-pvc monté sur TOUS les pods task (Nextflow merge ce pod
      // avec les directives pod des process individuels). Sans ce montage, les
      // tâches PREPARE_GENOME (GTF_FILTER, GETCHROMSIZES…) ne peuvent pas accéder
      // aux fichiers de référence — ils y sont accédés via symlink depuis le workdir
      // NFS mais la cible /data/reference n'existe que si le PVC est monté.
      pod = [
        [volumeClaim: 'nf-reference-pvc',
         mountPath  : '/data/reference',
         readOnly   : true],
      ]
    }

    process {
      executor = 'k8s'

      // ── Ressources par défaut — écrase les labels nf-core (process_high = 12 CPU) ──
      // Les labels nf-core (withLabel 'process_high') ont priorité sur les directives
      // cpus/memory au niveau process{}. Un withName: '.*' est obligatoire pour les
      // surcharger proprement. Il est placé EN PREMIER : les blocs withName spécifiques
      // ci-dessous (STAR_ALIGN, etc.) le surchargent car le dernier match gagne.
      withName: '.*' {
        cpus   = 2
        memory = '8.GB'
        time   = '4.h'
      }

      // ── STAR Align — goulot d'étranglement critique ───────────────────────
      // OOM si < 40 GB (index GRCh38 chargé entièrement en RAM).
      // 7 threads laissent la réserve système nécessaire sur un nœud 8 vCPU.
      withName: '.*STAR_ALIGN.*' {
        cpus    = 7
        memory  = '52.GB'
        time    = '8.h'
        // scratch=true : temp dir dans le workdir NFS (simple, bon pour POC)
        // Remplacer par un PVC SBS dédié pour production haute densité.
        scratch = true

        // Pas de volumeClaim nf-reference-pvc ici : le montage global k8s.pod
        // monte déjà /data/reference (readOnly) sur tous les pods.
        pod = [
          [nodeSelector: ['k8s.scaleway.com/pool-name': 'star-compute']],
          [toleration: [
            key      : 'workload',
            value    : 'star-compute',
            operator : 'Equal',
            effect   : 'NoSchedule',
          ]],
        ]

        // Upgrade vers scratch SBS haute IOPS (décommenter pour production) :
        // pod += [[volumeClaim: [
        //   claimName    : "star-scratch-${task.hash}",
        //   mountPath    : '/scratch',
        //   storageClass : 'star-scratch',
        //   accessMode   : 'ReadWriteOnce',
        //   storage      : '2000Gi',
        // ]]]
      }

      // ── STAR GenomeGenerate — one-shot, plus gourmand en RAM ─────────────
      // Dimensionné pour tenir sur le nœud POP2-HM-8C-64G du POC.
      // Déclenché automatiquement par nf-core si --star_index non fourni.
      withName: '.*STAR_GENOMEGENERATE.*' {
        cpus   = 7
        memory = '56.GB'
        time   = '6.h'

        // Pas de volumeClaim nf-reference-pvc ici : le montage global k8s.pod
        // monte déjà /data/reference (readOnly) sur tous les pods.
        // L'index généré est écrit dans le workdir NFS (pas dans nf-reference-pvc).
        pod = [
          [nodeSelector: ['k8s.scaleway.com/pool-name': 'star-compute']],
          [toleration: [
            key      : 'workload',
            value    : 'star-compute',
            operator : 'Equal',
            effect   : 'NoSchedule',
          ]],
        ]
      }

      // ── HISAT2 (alternative à STAR) ───────────────────────────────────────
      withName: '.*HISAT2_ALIGN.*' {
        cpus   = 7
        memory = '52.GB'
        time   = '8.h'
        pod = [
          [nodeSelector: ['k8s.scaleway.com/pool-name': 'star-compute']],
          [toleration: [key: 'workload', value: 'star-compute',
                        operator: 'Equal', effect: 'NoSchedule']],
        ]
      }

      // ── FastQC — léger, pool orchestrateur ───────────────────────────────
      // BASIC3-X4C-16G : 4 vCPU totaux, ~500m réservés système + head pod.
      // Max request viable par task : 2 CPU / 8 GB → ~1 task/nœud orchestrateur.
      withName: 'FASTQC' {
        cpus   = 2
        memory = '8.GB'
        time   = '2.h'
      }

      // ── Trimming (Trim Galore / fastp) ────────────────────────────────────
      // Même contrainte que FastQC : doit tenir sur orchestrateur 4 vCPU.
      // 2 CPU laisse de la marge pour le head pod et le pod système sur le même nœud.
      withName: '.*TRIM.*|.*FASTP.*|.*TRIMGALORE.*' {
        cpus   = 2
        memory = '8.GB'
        time   = '4.h'
      }

      // ── SAMtools sort — I/O intensive, sur le pool compute ────────────────
      withName: 'SAMTOOLS_SORT' {
        cpus   = 7
        memory = '32.GB'
        time   = '4.h'
        pod = [
          [nodeSelector: ['k8s.scaleway.com/pool-name': 'star-compute']],
          [toleration: [key: 'workload', value: 'star-compute',
                        operator: 'Equal', effect: 'NoSchedule']],
        ]
      }

      // ── Salmon INDEX — decoy-aware GRCh38 (~30-40 GB RAM) ───────────────────
      // gentrome.fa (transcriptome + génome) = ~3,3 Go chargé entièrement en RAM
      // par pufferfish. L'orchestrateur (16 GB) ne suffit pas → pool star-compute.
      withName: '.*SALMON_INDEX.*' {
        cpus   = 4
        memory = '32.GB'
        time   = '2.h'
        pod = [
          [nodeSelector: ['k8s.scaleway.com/pool-name': 'star-compute']],
          [toleration: [
            key      : 'workload',
            value    : 'star-compute',
            operator : 'Equal',
            effect   : 'NoSchedule',
          ]],
        ]
      }

      // ── featureCounts / HTSeq — légers, pool orchestrateur ───────────────
      withName: '.*SUBREAD.*|.*HTSEQ.*|.*FEATURECOUNTS.*' {
        cpus   = 2
        memory = '8.GB'
        time   = '2.h'
      }

      // ── Salmon quant — charge l'index pufferfish GRCh38 en RAM (~20-25 GB) ──
      // Vaut aussi pour FASTQ_SUBSAMPLE_FQ_SALMON:SALMON_QUANT (strandedness
      // detection) qui utilise --skipQuant mais charge quand même l'index complet.
      withName: '.*SALMON_QUANT.*' {
        cpus   = 2
        memory = '24.GB'
        time   = '2.h'
        pod = [
          [nodeSelector: ['k8s.scaleway.com/pool-name': 'star-compute']],
          [toleration: [
            key      : 'workload',
            value    : 'star-compute',
            operator : 'Equal',
            effect   : 'NoSchedule',
          ]],
        ]
      }

      // ── MultiQC — agrégation des rapports QC ──────────────────────────────
      withName: 'MULTIQC' {
        cpus   = 1
        memory = '4.GB'
        time   = '1.h'
      }
    }

    // Paramètres S3 — endpoint Scaleway Object Storage (compatible AWS SDK)
    aws {
      client {
        endpoint           = 'https://s3.fr-par.scw.cloud'
        // Requis par les stockages S3 compatibles hors AWS (dont Scaleway).
        s3PathStyleAccess  = true
        maxConnections     = 20
        maxErrorRetry      = 5
        uploadStorageClass = 'STANDARD'
      }
    }
  }

  // Sur le dataset minimal, toutes les tâches génériques doivent tenir sur le
  // pool orchestrateur. À combiner après scaleway_kapsule dans smoke-test.sh.
  scaleway_smoke {
    process {
      withName: '.*' {
        cpus   = 2
        memory = '8.GB'
        time   = '2.h'
      }
    }
  }

}
