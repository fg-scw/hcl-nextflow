# Copier vers terraform.tfvars et remplir les valeurs.
# Ne jamais committer terraform.tfvars (contient des secrets).

scw_access_key = "SCW_ACCESS_KEY_HERE"
scw_secret_key = "SCW_SECRET_KEY_HERE"
scw_project_id = "PROJECT_ID_HERE"

# ── Infrastructure ────────────────────────────────────────────────────────────
cluster_name    = "nf-kapsule"
scaleway_region = "fr-par"
scaleway_zone   = "fr-par-1"
k8s_version     = "1.35.3"
# Versions disponibles : scw k8s version list region=fr-par

# ── Compute ───────────────────────────────────────────────────────────────────
# POP2 fr-par-1 (requis pour SFS CSI) : 1 job STAR par nœud à 8 vCPU/52 GB
orchestrator_node_type = "POP2-4C-16G"
compute_node_type      = "POP2-HM-8C-64G"
compute_max_nodes      = 10

# Variante production (meilleur packing, même famille POP2) :
# compute_node_type  = "POP2-HM-32C-256G"   # 4 jobs/nœud → compute_max_nodes = 3
# compute_node_type  = "POP2-HM-16C-128G"   # 2 jobs/nœud → compute_max_nodes = 5

# ── Storage ───────────────────────────────────────────────────────────────────
# Production : 2 To SFS workdir + 500 Go SFS reference
workdir_size_gb      = 2000
reference_size_gb    = 500
star_scratch_size_gi = 2000

# Tests rapides (réduire pour limiter les coûts)
# workdir_size_gb      = 200
# reference_size_gb    = 100
# star_scratch_size_gi = 200

# ── Tags ──────────────────────────────────────────────────────────────────────
tags = ["env=poc", "project=nf-rnaseq", "pipeline=nf-core-rnaseq", "owner=hcl"]
